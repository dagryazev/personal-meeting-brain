# Required for embeddings (ingest + search).
VOYAGE_API_KEY=

# Required for the Streamlit demo to generate answers via Gemini.
GEMINI_API_KEY=

# Optional: override paths (defaults shown). Useful for containers / volumes.
# MEETING_BRAIN_TRANSCRIPTS_DIR=/app/transcripts
# MEETING_BRAIN_DB_PATH=/app/data/meetings.db

# Optional: override embedding model. voyage-3 is 1024-dim, which matches the
# DB schema — do NOT switch to a model with a different dimensionality without
# also writing a migration.
# MEETING_BRAIN_EMBED_MODEL=voyage-3
